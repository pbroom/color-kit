{
  "name": "color-kit",
  "version": "0.0.1",
  "description": "A queryable color-space engine for building color tooling: OKLCH-canonical conversion, contrast, gamut geometry, and plane queries, with React bindings as one consumer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./driver": {
      "import": {
        "types": "./dist/driver/index.d.ts",
        "default": "./dist/driver/index.js"
      },
      "require": {
        "types": "./dist/driver/index.d.cts",
        "default": "./dist/driver/index.cjs"
      }
    },
    "./plane": {
      "import": {
        "types": "./dist/plane/index.d.ts",
        "default": "./dist/plane/index.js"
      },
      "require": {
        "types": "./dist/plane/index.d.cts",
        "default": "./dist/plane/index.cjs"
      }
    },
    "./compute": {
      "import": {
        "types": "./dist/compute/index.d.ts",
        "default": "./dist/compute/index.js"
      },
      "require": {
        "types": "./dist/compute/index.d.cts",
        "default": "./dist/compute/index.cjs"
      }
    },
    "./hct": {
      "import": {
        "types": "./dist/hct/index.d.ts",
        "default": "./dist/hct/index.js"
      },
      "require": {
        "types": "./dist/hct/index.d.cts",
        "default": "./dist/hct/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./react/color-input": {
      "import": {
        "types": "./dist/react/color-input.d.ts",
        "default": "./dist/react/color-input.js"
      },
      "require": {
        "types": "./dist/react/color-input.d.cts",
        "default": "./dist/react/color-input.cjs"
      }
    },
    "./wasm": {
      "import": {
        "types": "./dist/wasm/index.d.ts",
        "default": "./dist/wasm/index.js"
      },
      "require": {
        "types": "./dist/wasm/index.d.cts",
        "default": "./dist/wasm/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "node ./scripts/prebuild.mjs",
    "build": "node ./scripts/build.mjs",
    "dev": "node --watch-path ../core/dist --watch-path ../driver/dist --watch-path ../react/dist --watch-path ../core-wasm/dist --watch-path ./scripts ./scripts/build.mjs",
    "pretest": "pnpm run build",
    "test": "node ./scripts/test-exports.mjs"
  },
  "keywords": [
    "color",
    "color-space",
    "oklch",
    "gamut",
    "display-p3",
    "contrast",
    "apca",
    "color-engine",
    "color-picker",
    "react"
  ],
  "author": "pbroom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pbroom/color-kit.git",
    "directory": "packages/color-kit"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.1",
    "@color-kit/control-kit": "*",
    "radix-ui": "^1.4.3",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@color-kit/control-kit": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@legendapp/state": "^2.1.15"
  },
  "devDependencies": {
    "@color-kit/control-kit": "github:pbroom/control-kit#b9cd2cbb9427707f10751a694bb3c9ac8b5f7289"
  }
}
