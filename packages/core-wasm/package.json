{
  "name": "@color-kit/core-wasm",
  "version": "0.0.1",
  "description": "Experimental WASM compute backends for @color-kit/core",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "rust"
  ],
  "scripts": {
    "build": "tsup",
    "build:all": "pnpm run build && pnpm run build:wasm",
    "dev": "tsup --watch",
    "build:wasm": "bash ./scripts/build-wasm.sh",
    "test": "vitest run --passWithNoTests",
    "check:rust": "cargo test --manifest-path ./rust/Cargo.toml",
    "check:wasm": "pnpm run build && pnpm run check:rust && pnpm run build:wasm"
  },
  "keywords": [
    "color",
    "wasm",
    "oklch",
    "performance"
  ],
  "author": "pbroom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pbroom/color-kit.git",
    "directory": "packages/core-wasm"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "dependencies": {
    "@color-kit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
