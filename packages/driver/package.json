{
  "name": "@color-kit/driver",
  "version": "0.0.1",
  "private": true,
  "description": "Framework-agnostic interaction drivers for color UI: area/slider/input math, gradients, parsing, and dual-state color model",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "color",
    "oklch",
    "headless",
    "color-picker",
    "framework-agnostic"
  ],
  "author": "pbroom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pbroom/color-kit.git",
    "directory": "packages/driver"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "dependencies": {
    "@color-kit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
