{
  "name": "@color-kit/react",
  "version": "0.0.1",
  "description": "Headless React primitives for building color interfaces",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "pretest:wasm-parity": "pnpm --filter @color-kit/core-wasm build:all",
    "pretest:wasm-parity:strict": "pnpm --filter @color-kit/core-wasm build:all",
    "test": "vitest run --passWithNoTests",
    "test:wasm-parity": "vitest run __tests__/plane-query-worker-parity.test.ts __tests__/wasm-parity-gate.test.ts __tests__/plane-query-worker-real-wasm.test.ts",
    "test:wasm-parity:strict": "COLOR_KIT_WASM_PARITY_GATE=strict COLOR_KIT_REQUIRE_REAL_WASM=1 vitest run __tests__/plane-query-worker-parity.test.ts __tests__/wasm-parity-gate.test.ts __tests__/plane-query-worker-real-wasm.test.ts",
    "test:watch": "vitest",
    "bench:color-plane": "node bench/color-plane-renderer-bench.mjs",
    "bench:color-area": "node bench/color-area-interaction-bench.mjs"
  },
  "keywords": [
    "color-picker",
    "react",
    "headless",
    "ui-components",
    "accessibility",
    "oklch"
  ],
  "author": "pbroom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pbroom/color-kit.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "dependencies": {
    "@color-kit/core": "workspace:*",
    "@color-kit/core-wasm": "workspace:*",
    "@legendapp/state": "^2.1.15"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
