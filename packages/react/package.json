{
  "name": "@color-kit/react",
  "version": "0.0.1",
  "private": true,
  "description": "Headless React primitives for building color interfaces",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./color-input": {
      "import": {
        "types": "./dist/color-input.d.ts",
        "default": "./dist/color-input.js"
      },
      "require": {
        "types": "./dist/color-input.d.cts",
        "default": "./dist/color-input.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "bench:color-plane": "node bench/color-plane-renderer-bench.mjs",
    "bench:color-area": "node bench/color-area-interaction-bench.mjs"
  },
  "keywords": [
    "color-picker",
    "react",
    "headless",
    "ui-components",
    "accessibility",
    "oklch"
  ],
  "author": "pbroom",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pbroom/color-kit.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public",
    "tag": "next"
  },
  "dependencies": {
    "@color-kit/core": "workspace:*",
    "@color-kit/driver": "workspace:*"
  },
  "peerDependencies": {
    "@color-kit/control-kit": "*",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@color-kit/control-kit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@color-kit/control-kit": "github:pbroom/control-kit#b9cd2cbb9427707f10751a694bb3c9ac8b5f7289",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
